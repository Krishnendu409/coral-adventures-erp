# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example is safe to commit (no secrets), .env.local is NOT
.env*
!.env.example
!system/.env.example
.env.local
system/.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite databases (runtime data, not source code)
*.db
*.sqlite
*.sqlite3
system/coral.db

# Local operational data — keep folder structure, ignore runtime files
/data/*
!/data/.keep
system/data/*
!system/data/.keep
!system/data/archive/.keep
!system/data/backups/.keep
!system/data/configuration/.keep
!system/data/database/.keep
!system/data/logs/.keep
!system/data/templates/.keep
system/src/server/db/data/*.db

# User-facing trip data folders — created at runtime, not source code
/incoming/
/exports/
/reports/
/generated/

# Scratch / test files
test-perf.ts
test.pdf
system/test-action.ts
system/test-db.ts
